ga() {
    git status --short \
        | fzf -m --bind 'tab:toggle+clear-query' \
        | awk '{print $2}' \
        | tr '\n' '\0' \
        | xargs -0 git add
}

gr() {
    git status --short \
        | fzf -m --bind 'tab:toggle+clear-query' \
        | awk '{print $2}' \
        | tr '\n' '\0' \
        | xargs -0 git restore
}

gs() {
    git status -sb
}
