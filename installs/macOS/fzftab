#!/usr/bin/env bash
set -euo pipefail

echo "Installing fzf-tab on macOS..."

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is required. Install it from https://brew.sh/"
  exit 1
fi

brew install git

FZF_TAB_DIR="$HOME/dippindots/.fzf-tab"

if [[ ! -d "$FZF_TAB_DIR/.git" ]]; then
  git clone https://github.com/Aloxaf/fzf-tab "$FZF_TAB_DIR"
else
  git -C "$FZF_TAB_DIR" pull --ff-only --quiet
fi

echo "Done."
