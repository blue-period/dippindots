#!/usr/bin/env bash
set -euo pipefail

echo "Installing fzf on Ubuntu..."

if ! command -v apt >/dev/null 2>&1; then
  echo "This installer expects Ubuntu with apt available."
  exit 1
fi

sudo apt update
sudo apt install -y fzf

echo "Done."
echo "Make sure your ~/.zshrc has:"
echo 'source <(fzf --zsh)'
