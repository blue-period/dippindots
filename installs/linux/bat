#!/usr/bin/env bash
set -euo pipefail

echo "Installing bat on Ubuntu..."

if ! command -v apt >/dev/null 2>&1; then
  echo "This installer expects Ubuntu with apt available."
  exit 1
fi

sudo apt update
sudo apt install -y bat

# Ubuntu/Debian package the binary as batcat.
if command -v batcat >/dev/null 2>&1 && ! command -v bat >/dev/null 2>&1; then
  mkdir -p "$HOME/.local/bin"
  ln -sf /usr/bin/batcat "$HOME/.local/bin/bat"
  echo "Linked batcat to $HOME/.local/bin/bat"
fi

echo "Done."
echo "Verify with: bat --version"
