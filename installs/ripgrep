#!/usr/bin/env bash

set -euo pipefail

REPO_URL="https://github.com/BurntSushi/ripgrep.git"
INSTALL_DIR="${HOME}/tools/ripgrep"

# Clone if missing, otherwise update
if [ ! -d "${INSTALL_DIR}/.git" ]; then
    echo "ripgrep not found. Cloning..."
    mkdir -p "$(dirname "${INSTALL_DIR}")"
    git clone "${REPO_URL}" "${INSTALL_DIR}"
else
    echo "ripgrep already exists. Pulling latest changes..."
    git -C "${INSTALL_DIR}" pull --ff-only
fi

# Build if cargo exists
if command -v cargo >/dev/null 2>&1; then
    echo "Building ripgrep..."
    cd "${INSTALL_DIR}"
    cargo build --release

    echo
    echo "ripgrep built successfully."
    echo "Binary location:"
    echo "  ${INSTALL_DIR}/target/release/rg"
else
    echo
    echo "Rust cargo is not installed."
    echo "Install Rust first:"
    echo "  curl https://sh.rustup.rs -sSf | sh"
    exit 1
fi
