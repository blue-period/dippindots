FZF_TAB_DIR="$HOME/dippindots/.fzf-tab"

# completion styles
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' menu no
zstyle ':fzf-tab:*' use-fzf-default-opts yes
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color=always "$realpath"'

# zsh completions
autoload -Uz compinit
compinit

source <(fzf --zsh)
# restore normal tab behavior
bindkey '^I' expand-or-complete
# bind fzf-tab to Esc-T
bindkey '^[t' fzf-tab-complete
# bind fzf file picker to Esc-G
bindkey '^[g' fzf-file-widget
#remove ctr-t
bindkey -r '^T'

# load fzf-tab last among completion-related plugins
source "$FZF_TAB_DIR/fzf-tab.plugin.zsh"

# What you get now:
# <Tab> → fzf-tab
# Esc-T → recursive fuzzy file search
# Alt-C or Esc-C → fuzzy cd into directories
# Ctrl-R → fuzzy history search
